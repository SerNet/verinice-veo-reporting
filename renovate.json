{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":automergeAll",
    ":automergePr"
  ],
  "reviewers": [
    "JJ",
    "JK"
  ],
  "assignAutomerge": true,
  "packageRules": [
    {
      "groupName": "OpenHTMLtoPDF",
      "matchPackageNames": [
        "/^io.github.openhtmltopdf:/"
      ]
    },
    {
      "groupName": "ph-fonts",
      "matchPackageNames": [
        "/^com.helger.font:/"
      ]
    },
    {
      "groupName": "Spotless",
      "postUpgradeTasks": {
        "commands": [
          "./gradlew spotlessApply"
        ],
        "fileFilters": [
          "**/*"
        ]
      },
      "matchPackageNames": [
        "/^com.diffplug.spotless/"
      ]
    },
    {
      "groupName": "Batik",
      "matchPackageNames": [
        "/^org.apache.xmlgraphics:batik/"
      ]
    },
    {
      "groupName": "flexmark-java",
      "matchPackageNames": [
        "/^com.vladsch.flexmark:/"
      ]
    },
    {
      "matchPackageNames": [
        "eclipse-temurin"
      ],
      "allowedVersions": "25-jdk"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "**/build.gradle",
        "**/build.gradle.kts"
      ],
      "matchStrings": [
        "(?<depName>gcr\\.io\\/distroless\\/java[0-9]+-debian[0-9]+):(?<currentValue>[^'\"@\\s]+)(?:@(?<currentDigest>sha256:[a-fA-F0-9]+))?"
      ],
      "autoReplaceStringTemplate": "{{{depName}}}:{{#if newValue}}{{{newValue}}}{{else}}{{{currentValue}}}{{/if}}{{#if newDigest}}@{{{newDigest}}}{{/if}}",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ]
}
